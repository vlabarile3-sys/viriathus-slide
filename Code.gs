function generateSlides(config) {
try {
const dest = SlidesApp.openById(config.destinationId);
const tmpl = SlidesApp.openById(config.templateId);
const dateStr = (config.date ? new Date(config.date) : new Date()).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

let count = 0;
const templateSlide = tmpl.getSlides()[0];
const totalSlides = config.slides.length;

config.slides.forEach((data, i) => {
const s = dest.insertSlide(1 + i, templateSlide);
const slideNumFormatted = (i + 1).toString().padStart(2, '0');

s.replaceAllText('{{DATE}}', dateStr);
s.replaceAllText('{{SLIDE_NUM}}', slideNumFormatted);
s.replaceAllText('{{TOTAL_SLIDES}}', totalSlides.toString());
s.replaceAllText('{{USER}}', data.user || '');
s.replaceAllText('{{BOT}}', data.bot || '');
s.replaceAllText('{{DESCRIPTION}}', data.description || '');

s.getShapes().forEach(shape => {
if (!shape.getText) return;
const textRange = shape.getText();
let rawText = textRange.asString();

if (rawText.includes('{{EXPLANATION}}')) {
const content = data.explanation || "N/A";
const isSafe = /No Violation|Safe|Okay|OK/i.test(content);
const color = isSafe ? '#10b981' : '#ef4444';
textRange.replaceAllText('{{EXPLANATION}}', content);
textRange.getTextStyle().setForegroundColor(color);
rawText = textRange.asString();
}

processLinksInShape(textRange, rawText);
});
count++;
});

CacheService.getScriptCache().remove(`SIG_V5_OBJ_${config.destinationId}`);
return { success: true, url: dest.getUrl(), count: count };
} catch (e) { return { success: false, error: e.toString() }; }
}

function processLinksInShape(textRange, rawText) {
try {
let match;
const urlRegex = /(https?:\/\/[^\s]+)/g;
while ((match = urlRegex.exec(rawText)) !== null) {
const linkRange = textRange.getRange(match.index, match.index + match[0].length);
linkRange.getTextStyle().setLinkUrl(match[0]).setUnderline(true);
}
} catch(e) { }
}

function fixHistoricalWorkflows() {
const sheet = getDbSheet();
const data = sheet.getDataRange().getValues();
if (data.length <= 1) {
console.log("No data to correct.");
return;
}
let updatedWorkflows = [];
let changesCount = 0;

for (let i = 1; i < data.length; i++) {
let subject = data[i][1] ? data[i][1].toString() : ""; // Mi assicuro che sia una stringa
let currentWf = data[i][4];
let workflowLabels = [];
// Convertiamo l'intero subject in maiuscolo per la ricerca
let searchArea = subject.toUpperCase();
// Controlliamo i tag ovunque nel testo
if (/\bU18\b/.test(searchArea)) workflowLabels.push("U18");
if (/\b(ST|O18)\b/.test(searchArea)) workflowLabels.push("ST/O18");
if (/\bNPOV\b/.test(searchArea)) workflowLabels.push("NPOV");
if (/\b(WS|WORKSPACE)\b/.test(searchArea)) workflowLabels.push("Workspace/WS");
if (/\b(OUF|GEMINI OUF)\b/.test(searchArea)) workflowLabels.push("OUF");
if (/\b(AIM|AI MODE)\b/.test(searchArea)) workflowLabels.push("AI Mode");
if (/\bMAGI\b/.test(searchArea)) workflowLabels.push("MAGI");
// Applichiamo il fallback a U18 se non trova nulla
let workflowLabel = workflowLabels.length > 0 ? workflowLabels.join(", ") : "U18";
updatedWorkflows.push([workflowLabel]);
if (currentWf !== workflowLabel) {
changesCount++;
}
}

if (updatedWorkflows.length > 0) {
sheet.getRange(2, 5, updatedWorkflows.length, 1).setValues(updatedWorkflows);
}
console.log("✅ Remediation completed! " + changesCount + " rows have been re-classified.");
}


